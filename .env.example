# Gemini API key (server-side only, never exposed to client)
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Facilitator code — gates the admin-only endpoints
# (responses, generate, clear, vision DELETE). Pick any hard-to-guess string.
# The facilitator enters it once in /admin or /submissions.
ADMIN_TOKEN=

# Upstash Redis REST credentials
# Auto-injected by Vercel when you connect the Upstash integration
KV_REST_API_URL=
KV_REST_API_TOKEN=
